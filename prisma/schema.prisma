generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                  @id @default(uuid())
  fullName                String
  username                String                  @unique
  email                   String                  @unique
  password                String
  profileImage            String?
  role                    UserRole                @default(USER)
  bio                     String?
  isDeleted               Boolean                 @default(false)
  deletedAt               DateTime?
  subscriptionType        SubscriptionType        @default(BASIC)
  subscriptionEndDate     DateTime?
  coins                   Int                     @default(0)
  oauthProvider           String?
  oauthId                 String?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  blockedBy               Block[]                 @relation("Blocked")
  blockings               Block[]                 @relation("Blocker")
  bookmarks               Bookmark[]
  chapterLikes            ChapterLike[]
  comments                Comment[]
  commentLikes            CommentLike[]
  donationsGiven          Donation[]              @relation("DonationsGiven")
  donationsReceived       Donation[]              @relation("DonationsReceived")
  favorites               Favorite[]
  followers               Follow[]                @relation("followTarget")
  following               Follow[]                @relation("followSource")
  notifications           Notification[]
  notificationPreferences NotificationPreference?
  passwordResets          PasswordReset[]
  ratings                 Rating[]
  reports                 Report[]
  stories                 Story[]
  transactions            Transaction[]
  views                   View[]

  @@unique([oauthProvider, oauthId])
}

model ChapterLike {
  id        String   @id @default(uuid())
  userId    String
  chapterId String
  createdAt DateTime @default(now())
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  storyId   String
  score     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
}

model Follow {
  id         String   @id @default(uuid())
  followerId String
  followeeId String
  createdAt  DateTime @default(now())
  followee   User     @relation("followTarget", fields: [followeeId], references: [id], onDelete: Cascade)
  follower   User     @relation("followSource", fields: [followerId], references: [id], onDelete: Cascade)

  @@unique([followerId, followeeId])
  @@index([followeeId])
  @@index([followerId])
}

model Story {
  id             String      @id @default(uuid())
  title          String
  description    String?
  coverImage     String?
  authorId       String
  categoryId     String?
  chapterCount   Int         @default(0)
  status         StoryStatus @default(DRAFT)
  isAdultContent Boolean     @default(false)
  isDeleted      Boolean     @default(false)
  deletedAt      DateTime?
  avgRating      Float       @default(0)
  ratingCount    Int         @default(0)
  viewCount      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  bookmarks      Bookmark[]
  chapters       Chapter[]
  donations      Donation[]
  favorites      Favorite[]
  ratings        Rating[]
  author         User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category       Category?   @relation(fields: [categoryId], references: [id])
  tags           StoryTag[]
  views          View[]

  @@index([authorId])
  @@index([categoryId])
  @@index([status])
  @@index([createdAt])
}

model Chapter {
  id            String         @id @default(uuid())
  storyId       String
  chapterNumber Int
  title         String
  content       String
  status        ChapterStatus  @default(DRAFT)
  publishedAt   DateTime?
  isDeleted     Boolean        @default(false)
  deletedAt     DateTime?
  viewCount     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  likeCount     Int            @default(0)
  commentCount  Int            @default(0)
  story         Story          @relation(fields: [storyId], references: [id])
  likes         ChapterLike[]
  medias        ChapterMedia[]
  comments      Comment[]
  views         View[]

  @@unique([storyId, chapterNumber])
  @@index([storyId])
  @@index([status])
}

model ChapterMedia {
  id        String    @id @default(uuid())
  chapterId String
  type      MediaType
  url       String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  chapter   Chapter   @relation(fields: [chapterId], references: [id])

  @@index([chapterId])
}

model Category {
  id      String  @id @default(uuid())
  name    String  @unique
  stories Story[]
}

model Tag {
  id      String     @id @default(uuid())
  name    String     @unique
  stories StoryTag[]
}

model StoryTag {
  storyId String
  tagId   String
  story   Story  @relation(fields: [storyId], references: [id])
  tag     Tag    @relation(fields: [tagId], references: [id])

  @@id([storyId, tagId])
  @@index([tagId])
}

model Comment {
  id        String        @id @default(uuid())
  content   String
  userId    String
  chapterId String
  parentId  String?
  likeCount Int           @default(0)
  isEdited  Boolean       @default(false)
  isDeleted Boolean       @default(false)
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  chapter   Chapter       @relation(fields: [chapterId], references: [id])
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[]     @relation("CommentReplies")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes     CommentLike[]

  @@index([chapterId])
  @@index([userId])
  @@index([parentId])
}

model CommentLike {
  id        String   @id @default(uuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([userId])
  @@index([commentId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  message   String
  sourceId  String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  likes     Boolean  @default(true)
  comments  Boolean  @default(true)
  follows   Boolean  @default(true)
  donations Boolean  @default(true)
  favorites Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model View {
  id        String   @id @default(uuid())
  userId    String?
  storyId   String?
  chapterId String?
  sessionId String
  userAgent String?
  createdAt DateTime @default(now())
  chapter   Chapter? @relation(fields: [chapterId], references: [id])
  story     Story?   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storyId, createdAt])
  @@index([chapterId, createdAt])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  storyId   String
  note      String?
  category  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  storyId   String
  createdAt DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@index([storyId])
}

model Report {
  id        String       @id @default(uuid())
  userId    String
  contentId String
  target    ReportTarget
  reason    ReportReason
  details   String?
  status    ReportStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contentId])
  @@index([status])
}

model Transaction {
  id        String            @id @default(uuid())
  userId    String
  type      TransactionType
  status    TransactionStatus
  amount    Float
  currency  String
  metadata  Json?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
}

model Donation {
  id          String   @id @default(uuid())
  donatorId   String
  recipientId String
  storyId     String
  amount      Int
  message     String?
  createdAt   DateTime @default(now())
  donator     User     @relation("DonationsGiven", fields: [donatorId], references: [id], onDelete: Cascade)
  recipient   User     @relation("DonationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  story       Story    @relation(fields: [storyId], references: [id])

  @@index([donatorId])
  @@index([recipientId])
  @@index([storyId])
}

model PasswordReset {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionType {
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
}

enum StoryStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ChapterStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TransactionType {
  SUBSCRIPTION
  DONATION
  TOPUP
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ReportStatus {
  PENDING
  REVIEWED
  REJECTED
  RESOLVED
}

enum ReportReason {
  SPAM
  HARASSMENT
  COPYRIGHT
  INAPPROPRIATE_CONTENT
  VIOLENCE
  OTHER
}

enum ReportTarget {
  STORY
  CHAPTER
  COMMENT
  USER
}
